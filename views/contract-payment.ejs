<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Freelancer Payment Statement</title>
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            color: #1e293b;
            line-height: 1.4;
            margin: 5px;
            font-size: 13px;
            background-color: #ffffff;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
        }
        .header {
            background-color: #0f1e36;
            padding: 20px 25px;
            color: #ffffff;
        }
        .logo-container {
            display: flex;
            align-items: center;
            float: left;
        }
        .logo-icon {
            width: 36px;
            height: 36px;
            background-color: rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-right: 10px;
            float: left;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .logo-symbol {
            position: relative;
            width: 20px;
            height: 20px;
        }
        .logo-head {
            width: 6px;
            height: 6px;
            background-color: #38bdf8;
            border-radius: 50%;
            position: absolute;
            top: 2px;
            left: 7px;
        }
        .logo-body {
            width: 14px;
            height: 6px;
            border: 2px solid #38bdf8;
            border-bottom: none;
            border-radius: 6px 6px 0 0;
            position: absolute;
            bottom: 2px;
            left: 3px;
        }
        .logo-text {
            color: #ffffff;
            font-family: 'Helvetica Neue', Arial, sans-serif;
            font-weight: 800;
            line-height: 1.1;
            float: left;
            margin-top: 1px;
        }
        .logo-title {
            font-size: 14px;
            letter-spacing: 0.5px;
            font-weight: 800;
        }
        .logo-subtitle {
            font-size: 9px;
            color: #38bdf8;
            letter-spacing: 1px;
            font-weight: 700;
        }
        .header-meta {
            text-align: right;
            float: right;
        }
        .header-meta h1 {
            margin: 0 0 3px 0;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: capitalize;
            color: #ffffff;
        }
        .header-meta p {
            margin: 0;
            font-size: 11px;
            color: #94a3b8;
        }
        .header-sub-desc {
            font-size: 10px;
            color: #94a3b8;
            margin-top: 3px;
            clear: both;
            padding-top: 5px;
        }
        .clearfix {
            clear: both;
        }
        .content-body {
            padding: 20px 25px;
        }
        .section-header {
            font-size: 13px;
            font-weight: bold;
            color: #0f172a;
            margin-top: 15px;
            margin-bottom: 10px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-card {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 18px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }
        .avatar-circle {
            width: 40px;
            height: 40px;
            background-color: #4f46e5;
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            font-size: 14px;
            margin-right: 12px;
            float: left;
        }
        .info-details {
            float: left;
        }
        .info-details h3 {
            margin: 0 0 2px 0;
            font-size: 14px;
            font-weight: bold;
            color: #0f172a;
        }
        .info-details p {
            margin: 0 0 4px 0;
            font-size: 11px;
            color: #64748b;
        }
        .status-badge {
            background-color: #ecfdf5;
            color: #059669;
            font-size: 10px;
            font-weight: 600;
            padding: 1px 8px;
            border-radius: 10px;
            display: inline-block;
            border: 1px solid #a7f3d0;
        }
        .grid-box {
            display: table;
            width: 100%;
            margin-bottom: 15px;
        }
        .grid-row {
            display: table-row;
        }
        .grid-col {
            display: table-cell;
            width: 50%;
            padding-bottom: 10px;
        }
        .grid-label {
            font-size: 10px;
            color: #64748b;
            text-transform: uppercase;
            margin-bottom: 2px;
            display: block;
        }
        .grid-val {
            font-size: 13px;
            font-weight: bold;
            color: #0f172a;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
            margin-bottom: 15px;
        }
        th {
            background-color: #0f1e36;
            color: #ffffff;
            font-size: 11px;
            font-weight: bold;
            padding: 10px 12px;
            text-align: left;
        }
        th:first-child {
            border-top-left-radius: 6px;
            border-bottom-left-radius: 6px;
        }
        th:last-child {
            border-top-right-radius: 6px;
            border-bottom-right-radius: 6px;
            text-align: right;
        }
        td {
            padding: 10px 12px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 12px;
            color: #334155;
        }
        td:last-child {
            text-align: right;
            font-weight: bold;
        }
        .blue-text {
            color: #3b82f6;
        }
        .highlight-banner {
            background: #3b82f6;
            color: #ffffff;
            border-radius: 10px;
            padding: 15px 20px;
            margin-top: 15px;
            display: table;
            width: 100%;
            box-sizing: border-box;
        }
        .banner-left {
            display: table-cell;
            width: 35%;
            vertical-align: middle;
            border-right: 1px solid rgba(255, 255, 255, 0.2);
            padding-right: 15px;
        }
        .banner-left p {
            margin: 0;
            font-size: 10px;
            color: rgba(255, 255, 255, 0.8);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .banner-left h2 {
            margin: 3px 0 0 0;
            font-size: 22px;
            font-weight: 800;
        }
        .banner-right {
            display: table-cell;
            width: 65%;
            vertical-align: middle;
            padding-left: 15px;
            font-size: 11px;
            line-height: 1.4;
            color: rgba(255, 255, 255, 0.9);
        }
        .footer-sig-section {
            margin-top: 25px;
            border-top: 1px solid #e2e8f0;
            padding-top: 15px;
            width: 100%;
        }
        .sig-block {
            width: 50%;
            float: left;
        }
        .sig-block h4 {
            margin: 0 0 3px 0;
            font-size: 11px;
            color: #0f172a;
            font-weight: bold;
        }
        .sig-block p {
            margin: 0;
            font-size: 10px;
            color: #64748b;
        }
        .address-block {
            width: 50%;
            float: right;
            text-align: right;
            font-size: 10px;
            color: #64748b;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Header banner -->
        <div class="header">
            <div class="logo-container">
                <div class="logo-icon">
                    <div class="logo-symbol">
                        <span class="logo-head"></span>
                        <span class="logo-body"></span>
                    </div>
                </div>
                <div class="logo-text">
                    <div class="logo-title">TALENT</div>
                    <div class="logo-subtitle">HUB</div>
                </div>
            </div>
            
            <div class="header-meta">
                <h1>Payment Statement</h1>
                <p>Date: <%= date %></p>
                <p>Contract ID: <%= contractId %></p>
            </div>
            <div class="clearfix"></div>
            <div class="header-sub-desc">Freelancer Contract Earnings Report</div>
        </div>

        <div class="content-body">
            <!-- Freelancer Information -->
            <div class="section-header" style="margin-top: 0;">Freelancer Information</div>
            <div class="info-card">
                <% 
                    var initials = "";
                    if (freelancerName) {
                        var parts = freelancerName.split(" ");
                        initials = parts[0].charAt(0).toUpperCase();
                        if (parts.length > 1) {
                            initials += parts[parts.length - 1].charAt(0).toUpperCase();
                        }
                    } else {
                        initials = "FL";
                    }
                %>
                <div class="avatar-circle"><%= initials %></div>
                <div class="info-details">
                    <h3><%= freelancerName %></h3>
                    <p><%= freelancerTitle %> | <%= freelancerLocation %></p>
                    <div class="status-badge">&bull; Contract Completed Successfully</div>
                </div>
                <div class="clearfix"></div>
            </div>

            <!-- Contract Overview -->
            <div class="section-header">Contract Overview</div>
            <div class="grid-box">
                <div class="grid-row">
                    <div class="grid-col">
                        <span class="grid-label">Client Name</span>
                        <span class="grid-val"><%= clientName %></span>
                    </div>
                    <div class="grid-col">
                        <span class="grid-label">Project Title</span>
                        <span class="grid-val"><%= contractTitle %></span>
                    </div>
                </div>
                <div class="grid-row">
                    <div class="grid-col">
                        <span class="grid-label">Contract Type</span>
                        <span class="grid-val"><%= contractType %></span>
                    </div>
                    <div class="grid-col">
                        <span class="grid-label">Project Duration</span>
                        <span class="grid-val"><%= projectDuration %></span>
                    </div>
                </div>
            </div>

            <!-- Payment Breakdown -->
            <div class="section-header">Payment Breakdown</div>
            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th style="text-align: right;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Total Budget Paid by Client</td>
                        <td class="blue-text">$<%= amountPaid %></td>
                    </tr>
                    <tr>
                        <td>Talent Hub Service Fee (15%)</td>
                        <td>-$<%= serviceFee %></td>
                    </tr>
                    <tr>
                        <td>Freelancer Final Earnings</td>
                        <td>$<%= earnings %></td>
                    </tr>
                </tbody>
            </table>

            <!-- Highlight Banner -->
            <div class="highlight-banner">
                <div class="banner-left">
                    <p>Amount Received by Freelancer</p>
                    <h2>$<%= earnings %> USD</h2>
                </div>
                <div class="banner-right">
                    This payment statement confirms that the client successfully paid the total contract budget through Talent Hub. After deducting the 15% platform commission fee, the remaining amount was transferred to the freelancer.
                </div>
            </div>

            <!-- Signature & Address footer -->
            <div class="footer-sig-section">
                <div class="sig-block">
                    <h4>Authorized Signature</h4>
                    <p>Finance Operations Team</p>
                    <p>Talent Hub Global Inc.</p>
                </div>
                <div class="address-block">
                    530 Lytton Avenue, Suite 301<br/>
                    Palo Alto, CA 94301<br/>
                    www.talenthub.com
                </div>
                <div class="clearfix"></div>
            </div>
        </div>
    </div>

</body>
</html>
